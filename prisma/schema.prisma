generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  states    State[]
}

model State {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  countryId Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  country   Country    @relation(fields: [countryId], references: [id])
  districts District[]
}

model District {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  name         String
  stateId      Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  state        State         @relation(fields: [stateId], references: [id])
  subDistricts SubDistrict[]
}

model SubDistrict {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  name       String
  districtId Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  district   District  @relation(fields: [districtId], references: [id])
  villages   Village[]
}

model Village {
  id            Int         @id @default(autoincrement())
  code          String      @unique
  name          String
  subDistrictId Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  planType  String     @default("free")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  apiKeys   ApiKey[]
}

model ApiKey {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  secretHash String
  userId     Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  apiLogs    ApiLog[]
}

model ApiLog {
  id           Int      @id @default(autoincrement())
  apiKeyId     Int
  userId       Int
  endpoint     String
  responseTime Int
  statusCode   Int
  createdAt    DateTime @default(now())
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id])
}